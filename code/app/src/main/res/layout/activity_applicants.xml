<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Top bar: back + event name + date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="#888888"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvEventDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- three dot menu -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="Menu"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Event photo area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#E8E4F0"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/ivEventPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Event photo"
                    android:textColor="#888888"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Participants row (tap to expand) -->
            <LinearLayout
                android:id="@+id/rowParticipants"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_nav_active"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_person"
                    app:tint="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvParticipantsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="PARTICIPANTS | applicants: 0"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <ImageView
                    android:id="@+id/ivExpandIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="-90"
                    app:tint="#FFFFFF"/>
            </LinearLayout>

            <!-- Expandable applicants list -->
            <LinearLayout
                android:id="@+id/participantsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#F5F3FB"
                android:visibility="gone">

                <!-- Filter tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <Button
                        android:id="@+id/btnFilterAll"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="All"
                        android:textSize="11sp"
                        android:backgroundTint="#6B5FA6"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnFilterWaiting"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Waiting"
                        android:textSize="11sp"
                        android:backgroundTint="#E8E4F3"
                        android:textColor="#6B5FA6"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnFilterSelected"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Selected"
                        android:textSize="11sp"
                        android:backgroundTint="#E8E4F3"
                        android:textColor="#6B5FA6"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnFilterAccepted"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Accepted"
                        android:textSize="11sp"
                        android:backgroundTint="#E8E4F3"
                        android:textColor="#6B5FA6"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvApplicantCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingBottom="4dp"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/applicantsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- Editable fields card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="16dp"
                android:background="#F5F3FB"
                android:padding="16dp">

                <!-- Price -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Price $"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etPrice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:background="@null"
                        android:paddingBottom="4dp"/>

                    <ImageButton
                        android:id="@+id/btnClearPrice"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        app:tint="#888888"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="12dp"/>

                <!-- Draw Date -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Draw Date"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etDrawDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="dd-mm-yyyy"
                        android:inputType="text"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:background="@null"
                        android:paddingBottom="4dp"/>

                    <ImageButton
                        android:id="@+id/btnClearDrawDate"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        app:tint="#888888"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="12dp"/>

                <!-- Number of Guests -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Number of Guests"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etTotalSpots"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="number"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:background="@null"
                        android:paddingBottom="4dp"/>

                    <ImageButton
                        android:id="@+id/btnClearSpots"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        app:tint="#888888"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="12dp"/>

                <!-- Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Start here.."
                        android:inputType="textMultiLine"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:background="@null"
                        android:paddingBottom="4dp"/>

                    <ImageButton
                        android:id="@+id/btnClearDescription"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        app:tint="#888888"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDDDDD" android:layout_marginBottom="16dp"/>

                <!-- Delete + Run Lottery / Replacement buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnDeleteEvent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DELETE"
                        android:backgroundTint="#FFFFFF"
                        android:textColor="#000000"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnRunLottery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="RUN LOTTERY"
                        android:backgroundTint="#6B5FA6"
                        android:textColor="@android:color/white"/>

                    <Button
                        android:id="@+id/btnReplacementDraw"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DRAW REPLACEMENT"
                        android:backgroundTint="#6B5FA6"
                        android:textColor="@android:color/white"
                        android:visibility="gone"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnCancelNoShows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="CANCEL NO-SHOWS"
                    android:backgroundTint="#FF9800"
                    android:textColor="@android:color/white"
                    android:visibility="gone"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>