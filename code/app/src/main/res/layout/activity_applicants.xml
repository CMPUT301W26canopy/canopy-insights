<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="#888888"/>

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingStart="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnRunLottery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Run Lottery"
            android:backgroundTint="#6B5FA6"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnReplacementDraw"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Replacement"
            android:backgroundTint="#FF9800"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnCancelNoShows"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel No-Shows"
            android:backgroundTint="#FF9800"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnDeleteEvent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete"
            android:backgroundTint="#F44336"
            android:textColor="@android:color/white"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnFilterAll"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="All"
            android:textSize="11sp"
            android:backgroundTint="#6B5FA6"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFilterWaiting"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Waiting"
            android:textSize="11sp"
            android:backgroundTint="#E8E4F3"
            android:textColor="#6B5FA6"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFilterSelected"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Selected"
            android:textSize="11sp"
            android:backgroundTint="#E8E4F3"
            android:textColor="#6B5FA6"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFilterAccepted"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Accepted"
            android:textSize="11sp"
            android:backgroundTint="#E8E4F3"
            android:textColor="#6B5FA6"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvApplicantCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textColor="#888888"
        android:textSize="13sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/applicantsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"/>

</LinearLayout>