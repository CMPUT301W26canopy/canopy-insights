<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="20dp"
    android:elevation="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Registration Period"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Date"
        android:textSize="14sp"
        android:textColor="#6E647E"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etRegStartDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="YYYY-MM-DD"
        android:padding="12dp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="16dp"
        android:inputType="date"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="End Date"
        android:textSize="14sp"
        android:textColor="#6E647E"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etRegEndDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="YYYY-MM-DD"
        android:padding="12dp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="16dp"
        android:inputType="date"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waiting List Limit (Optional)"
        android:textSize="14sp"
        android:textColor="#6E647E"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etWaitlistLimit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="No limit"
        android:padding="12dp"
        android:background="@drawable/bg_input"
        android:layout_marginBottom="24dp"
        android:inputType="number"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelReg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:backgroundTint="#E8E4F3"
            android:textColor="#4A4458"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSaveReg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save"
            android:backgroundTint="#6B5FA6"
            android:textColor="@android:color/white"/>
    </LinearLayout>
</LinearLayout>